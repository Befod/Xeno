{
    "homepage": "https://github.com/dengxibo/sumatrapdf-plus",
    "description": "Windows 下的 PDF / 电子书阅读器，针对中文 EPUB/MOBI、离线查词、主题与 PDF 智能暗黑模式等做了增强。",
    "version": "3.7.11",
    "license": "GPL-3.0-only,BSD-2-Clause",
    "url": "https://github.com/dengxibo/sumatrapdf-plus/releases/download/v3.7.11/Sumatra.PDF.Plus.MainProgram.zip",
    "hash": "26674d8b8410424ce485ff4d9fcb05159ff6c160d740a20668d0493560e94219",
    "pre_install": [
        "$file = 'SumatraPDF-settings.txt'",
        "if (!(Test-Path \"$persist_dir\\$file\")) {",
        "    Write-Host 'File' $file 'does not exists. Creating.' -f Yellow",
        "    Set-Content \"$dir\\$file\" 'CheckForUpdates = false' -Encoding Ascii",
        "}",
        "Get-ChildItem \"$dir\\SumatraPDF-*.exe\" | Rename-Item -NewName 'SumatraPDF.exe'"
    ],
    "shortcuts": [
        [
            "SumatraPDF.exe",
            "SumatraPDF Plus"
        ]
    ],
    "persist": [
        "SumatraPDF-settings.txt",
        "sumatrapdfcache"
    ],
    "checkver": {
        "url": "https://github.com/dengxibo/sumatrapdf-plus/releases/latest",
        "regex": "/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/dengxibo/sumatrapdf-plus/releases/download/v$version/Sumatra.PDF.Plus.MainProgram.zip"
    }
}
